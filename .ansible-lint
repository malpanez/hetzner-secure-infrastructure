---
# Ansible Lint Configuration

# Exclude paths
exclude_paths:
  - .github/
  - .woodpecker/
  - .molecule/
  - .terraform/
  - venv/
  - '**/*.md'
  - ansible/roles/geerlingguy.*
  - roles/geerlingguy.*
  - ~/.ansible/roles/
  - ~/.ansible/collections/
  - '**/molecule/*/roles/'

# Enable specific rules
enable_list:
  - fqcn-builtins  # Require FQCN for builtin modules
  - no-handler     # Handlers should do one thing
  - no-jinja-when  # No Jinja2 in when conditions

# Skip specific rules
skip_list:
  - yaml[line-length]  # Line length checked by yamllint
  - name[casing]       # Allow flexible naming
  - role-name         # Allow flexible role naming
  - yaml[truthy]      # Allow yes/no as valid truthy values
  - run-once          # Allow run_once in tasks
  - key-order         # Allow flexible key ordering
  - schema[meta]      # ansible-lint 6.17.2 schema doesn't include Debian 13 Trixie

# Warn only (don't fail)
warn_list:
  - experimental
  - ignore-errors
  - no-changed-when
  - var-naming[no-role-prefix]  # 190 violations in register/set_fact — fix in separate pass

# Use specific Ansible version
# ansible_version: "2.15"

# Offline mode (don't check for updates)
offline: false

# Parseable format for CI
# parseable: true
