# AppArmor profile for MariaDB server (mariadbd) — WordPress DBs
# {{ ansible_managed }}
# ---------------------------------------------------------------------------
# OBSERVE-ONLY PROFILE — flags=(complain).
# LOGS denials but BLOCKS NOTHING. Harvest 24-72h with `aa-logprof` /
# `journalctl -k | grep apparmor=\"DENIED\"` before any switch to enforce. A
# surprise enforce that blocks the datadir, the unix socket or the binlog takes
# BOTH WordPress sites down (every cache-miss query fails).
#
# This REPLACES Debian's intentionally-empty stub at
# /etc/apparmor.d/usr.sbin.mariadbd (an ease-of-use default that ships AppArmor
# DISABLED for MariaDB). For this hardened, complain-first estate we want a real
# profile. The empty file is a dpkg conffile; on this host apt runs with
# --force-confold so an upgrade keeps THIS version (see role notes).
# ---------------------------------------------------------------------------

#include <tunables/global>

/usr/sbin/mariadbd flags=(complain) {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/mysql>

  # -- Capabilities (unit: Ambient=CAP_IPC_LOCK; NoNewPrivileges NOT set) ----
  capability dac_override,      # mysql-user file access across the datadir
  capability setuid,            # drop privileges when started as root
  capability setgid,
  capability sys_resource,      # setrlimit (NOFILE 32768, memlock)
  capability sys_nice,          # InnoDB IO/purge thread priorities
  capability ipc_lock,          # mlock buffer pool (CAP_IPC_LOCK ambient)

  # -- Network --------------------------------------------------------------
  network inet stream,          # bind 127.0.0.1:3306
  network inet6 stream,
  network inet dgram,           # host-name resolution (skip-name-resolve off)
  network inet6 dgram,
  network unix stream,          # /run/mysqld/mysqld.sock (clients incl. exporter)

  # -- Binary ---------------------------------------------------------------
  /usr/sbin/mariadbd mr,

  # -- Configuration (read-only) -------------------------------------------
  /etc/mysql/ r,
  /etc/mysql/** r,

  # -- Data dir (InnoDB/Aria files use fcntl/flock -> needs 'k') ------------
  /var/lib/mysql/ rw,
  /var/lib/mysql/** rwk,

  # -- Runtime dir (socket via abstractions/mysql; pid + aux here) ----------
  /run/mysqld/ rw,
  /run/mysqld/** rw,

  # -- Logs: error (mysql.log), slow (slow.log) AND binary log --------------
  # NOTE: binlog is LIVE on this host and lives UNDER /var/log/mysql, not the
  # datadir: log_bin=/var/log/mysql/mysql-bin (+ .index + #binlog_cache_files/).
  # 'k' because binlog/relay files take fcntl locks.
  /var/log/mysql/ rw,
  /var/log/mysql/** rwk,

  # -- Error messages (errmsg.sys) + charsets (MariaDB 11.x path) -----------
  # charsets/ is already granted by abstractions/mysql; errmsg.sys is not.
  /usr/share/mariadb/ r,
  /usr/share/mariadb/** r,

  # -- Storage-engine / auth plugins (dlopen -> needs 'm') ------------------
  /usr/lib/mysql/plugin/ r,
  /usr/lib/mysql/plugin/*.so mr,

  # -- On-disk temp tables (tmpdir defaults to /tmp; unit PrivateTmp=false) --
  /tmp/ rw,
  owner /tmp/** rwk,

  # -- systemd notify (Type=notify) -----------------------------------------
  /run/systemd/notify w,

  # -- Kernel/proc reads (memory autosizing, cpu count, self introspection) -
  @{PROC}/sys/vm/overcommit_memory r,
  @{PROC}/meminfo r,
  @{PROC}/stat r,
  @{PROC}/cpuinfo r,
  owner @{PROC}/@{pid}/status r,
  owner @{PROC}/@{pid}/stat r,
  owner @{PROC}/@{pid}/io r,
  owner @{PROC}/@{pid}/limits r,
  owner @{PROC}/@{pid}/fd/ r,
  /sys/devices/system/cpu/ r,
  /sys/devices/system/cpu/online r,
  /sys/devices/system/node/ r,
  /sys/kernel/mm/transparent_hugepage/enabled r,

  # -- Deny-list the dangerous (mariadbd must NEVER read these) --------------
  deny /etc/shadow r,
  deny /etc/gshadow r,

  # Local customizations (optional stub; `if exists` avoids a parse failure when
  # the role has not been told to create /etc/apparmor.d/local/usr.sbin.mariadbd)
  include if exists <local/usr.sbin.mariadbd>
}
