# Fail2ban configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
#
# Backend note: Debian 13 is journald-based. The sshd jail uses backend=systemd
# (reads SSH auth events from the journal — no logpath needed); file-based jails
# (nginx access logs) keep backend=auto + logpath.

[DEFAULT]
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
ignoreip = {{ fail2ban_ignoreip | join(' ') }}

{% for service in fail2ban_services %}
[{{ service.name }}]
enabled = {{ service.enabled | ternary('true', 'false') }}
port = {{ service.port }}
filter = {{ service.filter }}
backend = {{ service.backend | default('auto') }}
{% if (service.backend | default('auto')) != 'systemd' %}
logpath = {{ service.logpath }}
{% endif %}
maxretry = {{ service.maxretry }}
bantime = {{ service.bantime }}
findtime = {{ service.findtime }}
{% endfor %}
