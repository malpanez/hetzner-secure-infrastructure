---
# Encrypted secrets for all hosts
# SECURITY WARNING: This file MUST be encrypted before committing!
#
# Steps to use:
# 1. Copy to secrets.yml: cp secrets.yml.example secrets.yml
# 2. Generate passwords: openssl rand -base64 32
# 3. Replace all CHANGE_ME values below
# 4. Encrypt: ansible-vault encrypt secrets.yml
# 5. Store vault password in: ~/.ansible/vault_password

# Grafana Admin Credentials
vault_grafana_admin_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"

# MariaDB Root Password
vault_mariadb_root_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"

# WordPress Database Password
vault_wordpress_db_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"

# WordPress Admin Credentials (for wp-admin initial setup)
vault_nginx_wordpress_admin_user: "admin"
vault_nginx_wordpress_admin_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"
vault_nginx_wordpress_admin_email: "admin@example.com"

# WordPress Security Keys and Salts
# Generate at: https://api.wordpress.org/secret-key/1.1/salt/
# Copy each value (the part inside single quotes) to the corresponding variable
vault_nginx_wordpress_auth_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_nginx_wordpress_secure_auth_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_nginx_wordpress_logged_in_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_nginx_wordpress_nonce_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_nginx_wordpress_auth_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_nginx_wordpress_secure_auth_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_nginx_wordpress_logged_in_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_nginx_wordpress_nonce_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"

# Dual WordPress - Per-site Database Passwords
vault_wp_main_db_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"
vault_wp_academy_db_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"

# Academy WordPress Security Keys and Salts
# Generate at: https://api.wordpress.org/secret-key/1.1/salt/
vault_wp_academy_auth_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_wp_academy_secure_auth_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_wp_academy_logged_in_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_wp_academy_nonce_key: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_wp_academy_auth_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_wp_academy_secure_auth_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_wp_academy_logged_in_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"
vault_wp_academy_nonce_salt: "CHANGE_ME_GENERATE_FROM_WORDPRESS_API"

# OpenBao Transit Auto-Unseal Token (set after running site.yml bootstrap)
vault_openbao_transit_token: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"

# Cloudflare (required for DNS-01 Let's Encrypt)
vault_cloudflare_api_token: "CHANGE_ME_CLOUDFLARE_API_TOKEN"

# Cloudflare Origin Certificate (for HTTPS between Cloudflare and origin server)
# Generate at: Cloudflare Dashboard → SSL/TLS → Origin Server → Create Certificate
# Choose: RSA, 15 years validity, hostnames: yourdomain.com and *.yourdomain.com
vault_cloudflare_origin_cert: |
  -----BEGIN CERTIFICATE-----
  PASTE_YOUR_CLOUDFLARE_ORIGIN_CERTIFICATE_HERE
  -----END CERTIFICATE-----

vault_cloudflare_origin_key: |
  -----BEGIN PRIVATE KEY-----
  PASTE_YOUR_CLOUDFLARE_ORIGIN_PRIVATE_KEY_HERE
  -----END PRIVATE KEY-----

# MariaDB Exporter (for Prometheus mysqld_exporter)
vault_mariadb_exporter_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"

# WordPress Academy Admin Credentials
vault_wordpress_academy_admin_password: "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"

# SMTP (Zoho Mail -- optional, only if sending emails from WordPress)
# vault_smtp_user: "noreply@twomindstrading.com"
# vault_smtp_app_password: "CHANGE_ME_ZOHO_APP_PASSWORD"

# Stripe (optional, only if WooCommerce payments enabled)
# vault_stripe_publishable_key: "pk_live_CHANGE_ME"
# vault_stripe_secret_key: "sk_live_CHANGE_ME"
